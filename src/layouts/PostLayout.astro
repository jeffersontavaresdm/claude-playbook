---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagBadge from '../components/TagBadge.astro';
import { SITE_TITLE } from '../consts';
import { url } from '../utils/url';

type Props = CollectionEntry<'posts'>['data'] & {
	readingTime?: string;
};

const { title, description, date, updated, cover, tags, readingTime } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={`${title} · ${SITE_TITLE}`} description={description} />
	</head>
	<body class="bg-[color:var(--color-bg)] text-[color:var(--color-fg)] antialiased">
		<Header />
		<main class="mx-auto w-full max-w-3xl px-4 py-10">
			<article>
				<header class="mb-8">
					<h1 class="text-4xl font-bold tracking-tight leading-tight">{title}</h1>
					<p class="mt-3 text-base text-[color:var(--color-muted)]">{description}</p>
					<div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-[color:var(--color-muted)]">
						<FormattedDate date={date} />
						{readingTime && <span aria-hidden="true">·</span>}
						{readingTime && <span>{readingTime}</span>}
						{updated && <span aria-hidden="true">·</span>}
						{updated && (
							<span class="italic">
								Atualizado em <FormattedDate date={updated} />
							</span>
						)}
					</div>
					{tags && tags.length > 0 && (
						<div class="mt-4 flex flex-wrap gap-2">
							{tags.map((t) => <TagBadge tag={t} />)}
						</div>
					)}
				</header>
				{cover && (
					<div class="mb-8">
						<Image src={cover} alt="" class="w-full rounded-lg" widths={[480, 800, 1200]} sizes="(min-width: 768px) 720px, 100vw" />
					</div>
				)}
				<div class="prose">
					<slot />
				</div>
			</article>
			<nav class="mt-12 border-t border-[color:var(--color-border)] pt-6 text-sm">
				<a href={url('/artigos')} class="text-[color:var(--color-accent)] hover:underline">← Voltar para todos os artigos</a>
			</nav>
		</main>
		<Footer />
	</body>
</html>
