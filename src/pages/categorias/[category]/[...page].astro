---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { CATEGORY_LIST } from '../../../utils/categories';
import { url } from '../../../utils/url';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const all = await getCollection('posts');
	return CATEGORY_LIST.flatMap((cat) => {
		const posts = all
			.filter((p) => p.data.category === cat.key)
			.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
		return paginate(posts, {
			params: { category: cat.slug },
			props: { categoryKey: cat.key },
			pageSize: 5,
		});
	});
};

const { page, categoryKey } = Astro.props as {
	page: import('astro').Page<Awaited<ReturnType<typeof getCollection<'posts'>>>[number]>;
	categoryKey: string;
};
const meta = CATEGORY_LIST.find((c) => c.key === categoryKey);
if (!meta) throw new Error(`Categoria desconhecida: ${categoryKey}`);

const prevHref = page.url.prev ? url(page.url.prev) : null;
const nextHref = page.url.next ? url(page.url.next) : null;
---

<BaseLayout title={meta.label.toLowerCase()} description={meta.tagline}>
	<header class="mb-8 reveal">
		<div class="font-[family-name:var(--font-mono)] text-sm text-[color:var(--color-muted)]">
			<span class="text-[color:var(--color-prompt)]">$</span> {meta.prompt}
		</div>
		<h1 class="mt-1 font-[family-name:var(--font-mono)] text-2xl font-bold text-[color:var(--color-fg-strong)]">
			{meta.label.toLowerCase()}/ <span class="text-[color:var(--color-muted)]">({page.total})</span>
		</h1>
		<p class="mt-2 text-[color:var(--color-muted)]">{meta.tagline}</p>
		<a href={url('/artigos')} class="mt-3 inline-block font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)] hover:text-[color:var(--color-prompt)]">
			← cd ../artigos
		</a>
	</header>
	{page.data.length === 0 ? (
		<p class="font-[family-name:var(--font-mono)] text-sm text-[color:var(--color-muted)]">
			<span class="text-[color:var(--color-amber)]">›</span> diretório vazio. em breve.
		</p>
	) : (
		<div class="reveal reveal-delay-1">
			{page.data.map((post) => (
				<PostCard
					href={url(`/artigos/${post.id}`)}
					title={post.data.title}
					description={post.data.description}
					date={post.data.date}
					tags={post.data.tags}
					slug={post.id}
				/>
			))}
		</div>
	)}
	{page.lastPage > 1 && (
		<nav class="mt-8 flex items-center justify-between gap-3 font-[family-name:var(--font-mono)] text-sm">
			{prevHref ? (
				<a href={prevHref} class="text-[color:var(--color-muted)] hover:text-[color:var(--color-prompt)]">
					← página {page.currentPage - 1}
				</a>
			) : (
				<span class="text-[color:var(--color-border-strong)]">← página</span>
			)}
			<span class="text-[color:var(--color-muted)]">
				<span class="text-[color:var(--color-amber)]">{page.currentPage}</span>
				<span class="text-[color:var(--color-border-strong)]">/</span>{page.lastPage}
			</span>
			{nextHref ? (
				<a href={nextHref} class="text-[color:var(--color-muted)] hover:text-[color:var(--color-prompt)]">
					página {page.currentPage + 1} →
				</a>
			) : (
				<span class="text-[color:var(--color-border-strong)]">página →</span>
			)}
		</nav>
	)}
</BaseLayout>
