---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { CATEGORY_LIST, CATEGORIES } from '../../utils/categories';
import { url } from '../../utils/url';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const counts = new Map<string, number>();
for (const p of posts) {
	counts.set(p.data.category, (counts.get(p.data.category) ?? 0) + 1);
}

const searchData = posts.map((post) => {
	const cat = CATEGORIES[post.data.category as keyof typeof CATEGORIES];
	return {
		id: post.id,
		title: post.data.title,
		description: post.data.description,
		tags: post.data.tags,
		categoryLabel: cat?.label ?? '',
	};
});
---

<BaseLayout title="artigos" description="Hub de categorias do Claude Playbook.">
	<header class="mb-8 reveal">
		<div class="font-[family-name:var(--font-mono)] text-sm text-[color:var(--color-muted)]">
			<span class="text-[color:var(--color-prompt)]">$</span> ls <span class="text-[color:var(--color-amber)]">artigos/</span>
		</div>
		<h1 class="mt-1 font-[family-name:var(--font-mono)] text-2xl font-bold text-[color:var(--color-fg-strong)]">
			artigos <span class="text-[color:var(--color-muted)]">({posts.length} no total)</span>
		</h1>
		<p class="mt-2 text-sm text-[color:var(--color-muted)]">
			Escolha uma categoria pra começar. Posts dentro de cada uma estão ordenados por data.
		</p>
	</header>

	<section class="reveal reveal-delay-1 mb-6" aria-label="Buscar posts">
		<label
			for="post-search"
			class="flex items-center gap-2 rounded border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/60 px-3 py-2 font-[family-name:var(--font-mono)] text-sm transition-colors focus-within:border-[color:var(--color-prompt)]/60 focus-within:bg-[color:var(--color-bg-elevated)]"
		>
			<span class="text-[color:var(--color-prompt)]">$</span>
			<span class="text-[color:var(--color-muted)]">grep</span>
			<input
				id="post-search"
				type="search"
				autocomplete="off"
				spellcheck="false"
				placeholder='"título, descrição, tag..."'
				class="flex-1 appearance-none border-0 bg-transparent text-[color:var(--color-fg-strong)] placeholder:text-[color:var(--color-border-strong)] focus:outline-none focus-visible:outline-none [&::-webkit-search-cancel-button]:appearance-none [&::-webkit-search-decoration]:appearance-none"
			/>
			<span class="text-[color:var(--color-amber)]">artigos/</span>
		</label>
		<p
			id="search-summary"
			class="mt-2 hidden font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)]"
			aria-live="polite"
		></p>
	</section>

	<div id="search-results" class="reveal reveal-delay-2 hidden flex-col gap-3">
		{posts.map((post) => (
			<div data-search-item data-id={post.id} class="hidden flex-col gap-1">
				<p
					data-match-hint
					class="hidden font-[family-name:var(--font-mono)] text-[11px] text-[color:var(--color-muted)]"
				></p>
				<PostCard
					href={url(`/artigos/${post.id}`)}
					title={post.data.title}
					description={post.data.description}
					date={post.data.date}
					tags={post.data.tags}
					slug={post.id}
				/>
			</div>
		))}
		<p
			id="search-empty"
			class="hidden py-6 text-center font-[family-name:var(--font-mono)] text-sm text-[color:var(--color-muted)]"
		>
			<span class="text-[color:var(--color-amber)]">›</span> nenhum match. tenta outra palavra.
		</p>
	</div>

	<div id="categories-grid" class="reveal reveal-delay-1 grid gap-3">
		{CATEGORY_LIST.filter((cat) => (counts.get(cat.key) ?? 0) > 0).map((cat) => {
			const count = counts.get(cat.key) ?? 0;
			return (
				<a
					href={url(`/categorias/${cat.slug}`)}
					class="group block rounded border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/50 p-5 transition-all hover:border-[color:var(--color-prompt)]/60 hover:bg-[color:var(--color-bg-elevated)] hover:shadow-[0_0_24px_color-mix(in_oklab,var(--color-prompt)_10%,transparent)]"
				>
					<div class="flex items-baseline justify-between gap-3 font-[family-name:var(--font-mono)]">
						<div class="flex items-baseline gap-2">
							<span class="text-[color:var(--color-prompt)]">$</span>
							<span class="text-[color:var(--color-muted)] text-sm">cd</span>
							<span class="text-base font-bold text-[color:var(--color-fg-strong)] transition-colors group-hover:text-[color:var(--color-prompt)]">
								{cat.label.toLowerCase()}/
							</span>
						</div>
						<span class="text-xs text-[color:var(--color-muted)]">
							{count} {count === 1 ? 'artigo' : 'artigos'}
						</span>
					</div>
					<p class="mt-2 text-sm leading-relaxed text-[color:var(--color-fg)]/75">
						{cat.tagline}
					</p>
				</a>
			);
		})}
	</div>

	<script type="application/json" id="search-data" is:inline set:html={JSON.stringify(searchData)} />
</BaseLayout>

<script>
	import Fuse from 'fuse.js';

	type Doc = {
		id: string;
		title: string;
		description: string;
		tags: string[];
		categoryLabel: string;
	};

	const input = document.getElementById('post-search') as HTMLInputElement | null;
	const results = document.getElementById('search-results');
	const categories = document.getElementById('categories-grid');
	const summary = document.getElementById('search-summary');
	const empty = document.getElementById('search-empty');
	const dataEl = document.getElementById('search-data');

	const FIELD_LABEL: Record<string, string> = {
		title: 'título',
		tags: 'tag',
		description: 'descrição',
		categoryLabel: 'categoria',
	};

	if (input && results && categories && summary && empty && dataEl) {
		const docs: Doc[] = JSON.parse(dataEl.textContent || '[]');

		const fuse = new Fuse(docs, {
			keys: [
				{ name: 'title', weight: 0.5 },
				{ name: 'tags', weight: 0.3 },
				{ name: 'description', weight: 0.15 },
				{ name: 'categoryLabel', weight: 0.05 },
			],
			threshold: 0.3,
			ignoreLocation: true,
			minMatchCharLength: 2,
			includeMatches: true,
			includeScore: true,
		});

		const SCORE_CUTOFF = 0.5;

		const itemsById = new Map<string, HTMLElement>();
		for (const el of results.querySelectorAll<HTMLElement>('[data-search-item]')) {
			const id = el.dataset.id;
			if (id) itemsById.set(id, el);
		}

		const reset = () => {
			results.classList.add('hidden');
			results.classList.remove('flex');
			categories.classList.remove('hidden');
			summary.classList.add('hidden');
			summary.textContent = '';
			empty.classList.add('hidden');
			for (const el of itemsById.values()) {
				el.classList.add('hidden');
				el.classList.remove('flex');
				el.style.order = '';
				const hint = el.querySelector<HTMLElement>('[data-match-hint]');
				if (hint) {
					hint.classList.add('hidden');
					hint.textContent = '';
				}
			}
		};

		const apply = (raw: string) => {
			const q = raw.trim();
			if (!q) {
				reset();
				return;
			}

			const hits = fuse.search(q).filter((h) => (h.score ?? 1) <= SCORE_CUTOFF);

			for (const el of itemsById.values()) {
				el.classList.add('hidden');
				el.classList.remove('flex');
				el.style.order = '';
				const hint = el.querySelector<HTMLElement>('[data-match-hint]');
				if (hint) {
					hint.classList.add('hidden');
					hint.textContent = '';
				}
			}

			let matched = 0;
			hits.forEach((hit, idx) => {
				const el = itemsById.get(hit.item.id);
				if (!el) return;
				el.classList.remove('hidden');
				el.classList.add('flex');
				el.style.order = String(idx);
				matched++;

				const fields = (hit.matches ?? [])
					.map((m) => FIELD_LABEL[m.key ?? ''] ?? m.key ?? '')
					.filter(Boolean);
				const unique = Array.from(new Set(fields));
				const hint = el.querySelector<HTMLElement>('[data-match-hint]');
				if (hint && unique.length) {
					hint.textContent = `› match em ${unique.join(' + ')}`;
					hint.classList.remove('hidden');
				}
			});

			results.classList.remove('hidden');
			results.classList.add('flex');
			categories.classList.add('hidden');
			summary.classList.remove('hidden');
			summary.textContent = `› ${matched} ${matched === 1 ? 'match' : 'matches'} para "${q}"`;
			empty.classList.toggle('hidden', matched > 0);
		};

		input.addEventListener('input', () => apply(input.value));

		const params = new URLSearchParams(window.location.search);
		const initial = params.get('q');
		if (initial) {
			input.value = initial;
			apply(initial);
		}

		input.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				input.value = '';
				apply('');
				input.blur();
			}
		});
	}
</script>
</content>
</invoke>