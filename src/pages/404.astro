---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout title="Página não encontrada" description="404 — página não encontrada.">
	<div class="py-16 text-center">
		<p class="text-6xl font-bold text-[color:var(--color-accent)]">404</p>
		<h1 class="mt-4 text-2xl font-bold">Página não encontrada</h1>
		<p class="mt-3 text-[color:var(--color-muted)]">
			O caminho que você procurou não existe (ou ainda não existe).
		</p>
		<a
			href={url('/')}
			class="mt-6 inline-block rounded-md border border-[color:var(--color-border)] px-4 py-2 text-sm hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
		>
			← Voltar ao início
		</a>
	</div>
</BaseLayout>
