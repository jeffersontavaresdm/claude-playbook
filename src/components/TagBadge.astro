---
import { url } from '../utils/url';

interface Props {
	tag: string;
	count?: number;
}
const { tag, count } = Astro.props;
const slug = tag.toLowerCase().replace(/\s+/g, '-');
---

<a
	href={url(`/tags/${slug}`)}
	class="font-[family-name:var(--font-mono)] inline-flex items-center text-xs text-[color:var(--color-muted)] transition-colors hover:text-[color:var(--color-prompt)] hover:[&_.flag]:text-[color:var(--color-prompt)]"
>
	<span class="flag text-[color:var(--color-amber)]">--tag</span><span class="text-[color:var(--color-muted)]">=</span><span class="text-[color:var(--color-fg)]">{tag}</span>{count !== undefined && <span class="ml-0.5 text-[color:var(--color-muted)]">({count})</span>}
</a>
