---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { url } from '../utils/url';
---

<header class="border-b border-[color:var(--color-border)] bg-[color:var(--color-bg)]/80 backdrop-blur supports-[backdrop-filter]:bg-[color:var(--color-bg)]/60">
	<div class="mx-auto max-w-3xl px-4 py-5">
		<div class="flex flex-wrap items-center justify-between gap-3 font-[family-name:var(--font-mono)]">
			<a href={url('/')} class="group inline-flex items-baseline gap-1.5 text-sm sm:text-base">
				<span class="text-[color:var(--color-prompt)] font-bold drop-shadow-[0_0_8px_color-mix(in_oklab,var(--color-prompt)_60%,transparent)]">$</span>
				<span class="text-[color:var(--color-muted)]">cd</span>
				<span class="text-[color:var(--color-fg-strong)] font-semibold transition-colors group-hover:text-[color:var(--color-prompt)]">~/{SITE_TITLE}</span>
			</a>
			<nav class="flex items-center gap-1 text-sm">
				<HeaderLink href={url('/')}>início</HeaderLink>
				<span class="text-[color:var(--color-border-strong)]">·</span>
				<HeaderLink href={url('/artigos')}>artigos</HeaderLink>
				<span class="text-[color:var(--color-border-strong)]">·</span>
				<HeaderLink href={url('/tags')}>tags</HeaderLink>
				<span class="text-[color:var(--color-border-strong)]">·</span>
				<HeaderLink href={url('/sobre')}>sobre</HeaderLink>
				<span class="ml-2"></span>
				<ThemeToggle />
			</nav>
		</div>
	</div>
</header>
