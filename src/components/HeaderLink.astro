---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '');
const stripBase = (p: string) => (p.startsWith(base) ? p.slice(base.length) : p);
const pathname = stripBase(Astro.url.pathname).replace(/\/$/, '') || '/';
const target = stripBase(String(href ?? '/')).replace(/\/$/, '') || '/';
const isActive =
	target === pathname || (target !== '/' && pathname.startsWith(target));
---

<a
	href={href}
	data-active={isActive}
	class:list={[
		'group relative inline-flex items-center px-2 py-1 text-sm transition-colors',
		'text-[color:var(--color-muted)] hover:text-[color:var(--color-prompt)]',
		'data-[active=true]:text-[color:var(--color-prompt)]',
		className,
	]}
	{...props}
>
	<span class="text-[color:var(--color-border-strong)] group-hover:text-[color:var(--color-prompt)] group-data-[active=true]:text-[color:var(--color-prompt)]">[</span>
	<span class="px-0.5"><slot /></span>
	<span class="text-[color:var(--color-border-strong)] group-hover:text-[color:var(--color-prompt)] group-data-[active=true]:text-[color:var(--color-prompt)]">]</span>
</a>
