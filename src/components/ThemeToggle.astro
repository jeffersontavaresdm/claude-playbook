---
---

<button
	id="theme-toggle"
	type="button"
	aria-label="Alternar tema claro/escuro"
	class="font-[family-name:var(--font-mono)] inline-flex items-center gap-1 rounded border border-[color:var(--color-border-strong)] px-2 py-1 text-xs text-[color:var(--color-muted)] transition-all hover:border-[color:var(--color-prompt)] hover:text-[color:var(--color-prompt)] hover:shadow-[0_0_12px_color-mix(in_oklab,var(--color-prompt)_25%,transparent)]"
>
	<span class="text-[color:var(--color-border-strong)] inline-block group-hover:text-[color:var(--color-prompt)]">--theme=</span><span id="theme-toggle-label">dark</span>
</button>

<script is:inline>
	(function () {
		const STORAGE_KEY = 'theme';
		const root = document.documentElement;
		const button = document.getElementById('theme-toggle');
		const label = document.getElementById('theme-toggle-label');

		function getCurrentTheme() {
			return root.classList.contains('light') ? 'light' : 'dark';
		}
		function applyTheme(theme) {
			root.classList.toggle('light', theme === 'light');
			if (label) label.textContent = theme;
		}

		const stored = localStorage.getItem(STORAGE_KEY);
		const initial =
			stored ||
			(window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
		applyTheme(initial);

		if (button) {
			button.addEventListener('click', () => {
				const next = getCurrentTheme() === 'dark' ? 'light' : 'dark';
				applyTheme(next);
				localStorage.setItem(STORAGE_KEY, next);
			});
		}
	})();
</script>
