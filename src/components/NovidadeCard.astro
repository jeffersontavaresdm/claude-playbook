---
import FormattedDate from './FormattedDate.astro';

interface Props {
	titulo: string;
	tldr: string;
	resumo: string;
	fonteNome: string;
	fonteUrl: string;
	data: Date;
}

const { titulo, tldr, resumo, fonteNome, fonteUrl, data } = Astro.props;

let host = fonteNome;
try {
	host = new URL(fonteUrl).hostname.replace(/^www\./, '');
} catch {
	host = fonteNome;
}
---

<article class="group relative my-3 rounded border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/50 p-5 transition-all hover:border-[color:var(--color-prompt)]/60 hover:bg-[color:var(--color-bg-elevated)] hover:shadow-[0_0_24px_color-mix(in_oklab,var(--color-prompt)_10%,transparent)]">
	<div class="mb-2 flex items-center gap-2 font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)]">
		<span class="text-[color:var(--color-magenta)]"><FormattedDate date={data} /></span>
		<span class="text-[color:var(--color-border-strong)]">·</span>
		<span class="text-[color:var(--color-amber)]">{fonteNome}</span>
	</div>

	<a href={fonteUrl} target="_blank" rel="noopener noreferrer" class="block">
		<h3 class="font-[family-name:var(--font-mono)] text-lg font-bold tracking-tight text-[color:var(--color-fg-strong)] transition-colors group-hover:text-[color:var(--color-prompt)]">
			<span class="text-[color:var(--color-prompt)]">›</span> {titulo}
		</h3>
	</a>

	<p class="mt-2 flex gap-2 font-[family-name:var(--font-mono)] text-sm leading-relaxed text-[color:var(--color-fg)]/85">
		<span class="shrink-0 font-bold text-[color:var(--color-prompt)]">TL;DR</span>
		<span>{tldr}</span>
	</p>

	<p class="mt-2 leading-relaxed text-[color:var(--color-fg)]/75">{resumo}</p>

	<a
		href={fonteUrl}
		target="_blank"
		rel="noopener noreferrer"
		class="mt-3 inline-flex items-center gap-1 font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)] transition-colors hover:text-[color:var(--color-prompt)]"
	>
		<span class="text-[color:var(--color-prompt)]">→</span> ler na fonte
		<span class="text-[color:var(--color-border-strong)]">({host})</span>
	</a>
</article>
