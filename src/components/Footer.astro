---
import { AUTHOR, AUTHOR_URL, SITE_TITLE } from '../consts';
import { url } from '../utils/url';
const today = new Date();
---

<footer class="mt-16 border-t border-[color:var(--color-border)] py-8 text-sm text-[color:var(--color-muted)]">
	<div class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-3 px-4 sm:flex-row">
		<p>
			© {today.getFullYear()} {SITE_TITLE} ·
			<a href={AUTHOR_URL} class="hover:text-[color:var(--color-accent)] hover:underline" target="_blank" rel="noopener noreferrer">
				{AUTHOR}
			</a>
		</p>
		<div class="flex items-center gap-4">
			<a href={url('/rss.xml')} class="hover:text-[color:var(--color-accent)] hover:underline">RSS</a>
			<a href={AUTHOR_URL} class="hover:text-[color:var(--color-accent)] hover:underline" target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</div>
</footer>
