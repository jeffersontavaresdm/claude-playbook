---
import { GITHUB_URL, LINKEDIN_URL, SITE_TITLE } from '../consts';
import SocialIcon from './SocialIcon.astro';
const today = new Date();
---

<footer class="mt-20 border-t border-[color:var(--color-border-strong)] bg-[color:var(--color-bg-elevated)]/40 py-6 font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)]">
	<div class="mx-auto max-w-3xl px-4">
		<div class="flex flex-wrap items-center justify-center gap-2 sm:justify-start">
			<SocialIcon href={GITHUB_URL} label="GitHub do autor" icon="github">github</SocialIcon>
			<SocialIcon href={LINKEDIN_URL} label="LinkedIn do autor" icon="linkedin">linkedin</SocialIcon>
		</div>
		<div class="mt-5 flex flex-wrap items-center justify-between gap-2 border-t border-dashed border-[color:var(--color-border)] pt-4 text-[10px] uppercase tracking-widest">
			<span class="text-[color:var(--color-prompt)]">[ NORMAL ]</span>
			<span>{SITE_TITLE} · v0.1 · © {today.getFullYear()}</span>
			<span class="text-[color:var(--color-amber)]">UTF-8 · pt-BR</span>
		</div>
	</div>
</footer>
