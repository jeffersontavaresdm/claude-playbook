---
import FormattedDate from './FormattedDate.astro';
import TagBadge from './TagBadge.astro';

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	tags: string[];
}

const { href, title, description, date, tags } = Astro.props;
---

<article class="group border-b border-[color:var(--color-border)] py-6 last:border-b-0">
	<a href={href} class="block">
		<h3 class="text-xl font-bold tracking-tight transition-colors group-hover:text-[color:var(--color-accent)]">
			{title}
		</h3>
		<p class="mt-2 text-sm text-[color:var(--color-muted)]">
			<FormattedDate date={date} />
		</p>
		<p class="mt-2 leading-relaxed text-[color:var(--color-fg)]/85">{description}</p>
	</a>
	{tags.length > 0 && (
		<div class="mt-3 flex flex-wrap gap-2">
			{tags.map((t) => <TagBadge tag={t} />)}
		</div>
	)}
</article>
