---
import FormattedDate from './FormattedDate.astro';
import TagBadge from './TagBadge.astro';

interface Props {
	href: string;
	title: string;
	description: string;
	date: Date;
	tags: string[];
	slug?: string;
}

const { href, title, description, date, tags, slug } = Astro.props;
const filename = slug ? `${slug}.md` : `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}.md`;
---

<article class="group relative my-3 rounded border border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]/50 p-5 transition-all hover:border-[color:var(--color-prompt)]/60 hover:bg-[color:var(--color-bg-elevated)] hover:shadow-[0_0_24px_color-mix(in_oklab,var(--color-prompt)_10%,transparent)]">
	<div class="mb-2 flex items-center gap-2 font-[family-name:var(--font-mono)] text-xs text-[color:var(--color-muted)]">
		<span class="text-[color:var(--color-magenta)]"><FormattedDate date={date} /></span>
		<span class="text-[color:var(--color-border-strong)]">·</span>
		<span class="text-[color:var(--color-amber)]">{filename}</span>
	</div>
	<a href={href} class="block">
		<h3 class="font-[family-name:var(--font-mono)] text-lg font-bold tracking-tight text-[color:var(--color-fg-strong)] transition-colors group-hover:text-[color:var(--color-prompt)]">
			<span class="text-[color:var(--color-prompt)]">›</span> {title}
		</h3>
		<p class="mt-2 leading-relaxed text-[color:var(--color-fg)]/80">{description}</p>
	</a>
	{tags.length > 0 && (
		<div class="mt-3 flex flex-wrap gap-1.5 font-[family-name:var(--font-mono)]">
			{tags.map((t) => <TagBadge tag={t} />)}
		</div>
	)}
</article>
